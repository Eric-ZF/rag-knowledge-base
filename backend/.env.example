# Phase 0 环境变量配置
# 复制为 .env 并填入真实值

# ─── MiniMax（Phase 0 使用）─────────────────────────────
# MiniMax API Key（sk-cp 开头）
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax Group ID（账户级别参数，必需）
# 获取地址：https://platform.minimax.chat/user/login
# 登录后进入控制台 → 账户设置 → Group ID
MINIMAX_GROUP_ID=1234567890

# ─── 模型配置（通常不需要修改）────────────────────────
# Embedding: eambo-01（MiniMax 官方 Embedding 模型，1536 维）
# Chat: MiniMax-Text-01（200K context，OpenAI-compatible）
EMBEDDING_MODEL=embo-01
CHAT_MODEL=MiniMax-Text-01
MINIMAX_EMBED_ENDPOINT=https://api.minimax.chat/v1/embeddings
MINIMAX_CHAT_ENDPOINT=https://api.minimax.chat/v1/chat/completions

# ─── ChromaDB（Phase 0 向量库，无需修改）────────────────
# ChromaDB 持久化目录（Phase 0 用 /tmp，生产换 PostgreSQL 路径）
CHROMADB_DIR=/tmp/chromadb

# ─── 开发模式 ──────────────────────────────────────────
DEBUG=true
