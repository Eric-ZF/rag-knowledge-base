# Phase 0 环境变量配置
# 复制为 .env 并填入真实 key

# OpenAI（Embedding + 通用 LLM，Phase 0 使用）
OPENAI_API_KEY=sk-...

# Anthropic（Claude Haiku 用于 RAG 问答）
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant（本地开发用 Docker 启动）
QDRANT_URL=http://localhost:6333

# JWT 密钥（Phase 0 仅，⚠️ 生产必须换复杂密钥）
JWT_SECRET=phase0-dev-secret-change-in-production

# DEBUG 模式
DEBUG=true
